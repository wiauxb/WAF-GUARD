FROM postgres:17.6

# Copy SQL files for database initialization
COPY docker/scripts/cwaf_db.sql /init/
COPY docker/scripts/files_db.sql /init/
COPY docker/scripts/chatbot_db.sql /init/

# Copy initialization script
COPY docker/scripts/init-databases.sh /docker-entrypoint-initdb.d/

# Make the initialization script executable
RUN chmod +x /docker-entrypoint-initdb.d/init-databases.sh
